<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/ic_logo_apps"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SuciiApps"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <Button
                android:id="@+id/btnBangunRuang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HITUNG BANGUN RUANG (P2)"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnLes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PENDAFTARAN LES (P4)"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnWebView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WEB VIEW BINA DESA (P5)"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnPertemuan6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MATERI FRAGMENT (P6/7)"
                android:layout_marginBottom="40dp"/>

            <!-- TOMBOL LOGOUT (tambahkan ini) -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LOGOUT"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:layout_marginTop="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>