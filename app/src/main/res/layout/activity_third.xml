<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ic_logo_apps" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="LearnPath"
            android:textColor="@color/text_dark"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textAlignment="center" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp">

                <EditText
                    android:id="@+id/inputUsername"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Username"
                    android:paddingLeft="15dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="15dp"/>

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingLeft="15dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="25dp"/>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Login"
                    android:backgroundTint="@color/primary_start"
                    app:cornerRadius="15dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layoutDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnRumus"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="📐 Rumus Bangun Ruang"
                android:textColor="@color/text_dark"
                android:backgroundTint="@color/white"
                app:cornerRadius="15dp"
                android:layout_marginBottom="15dp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnLesIT"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="💻 Program Les IT Suci"
                android:textColor="@color/text_dark"
                android:backgroundTint="@color/white"
                app:cornerRadius="15dp"
                android:layout_marginBottom="15dp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnPendaftaran"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="📝 Info Pendaftaran"
                android:textColor="@color/text_dark"
                android:backgroundTint="@color/white"
                app:cornerRadius="15dp"
                android:layout_marginBottom="15dp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Keluar"
                android:backgroundTint="@color/error_red"
                app:cornerRadius="15dp"
                android:layout_marginTop="20dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>