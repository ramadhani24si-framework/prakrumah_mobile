<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" >

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Suciiapps"
        android:usesCleartextTraffic="true" >

        <!-- BASE ACTIVITY (Main Activity dengan BottomNav) -->
        <activity
            android:name=".BaseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustNothing" />

        <activity
            android:name=".AuthActivity"
            android:exported="false" />

        <!-- SPLASH SCREEN (LAUNCHER) -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== PERTEMUAN 2 ===== -->
        <activity
            android:name=".Home.pertemuan_2.SecondActivity"
            android:exported="false" />

        <!-- ===== PERTEMUAN 3 ===== -->
        <activity
            android:name=".Home.pertemuan_3.ThirdActivity"
            android:exported="false" />

        <!-- ===== PERTEMUAN 4 ===== -->
        <activity
            android:name=".Home.pertemuan_4.FourthActivity"
            android:exported="false" />

        <!-- ===== PERTEMUAN 5 ===== -->
        <activity
            android:name=".Home.pertemuan_5.FifthActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_5.WebViewActivity"
            android:exported="false" />

        <!-- ===== PERTEMUAN 7 ===== -->
        <activity
            android:name=".Home.pertemuan_7.SeventhActivity"
            android:exported="false" />

    </application>

</manifest>